# Azure AI Foundry / Voice Live API
# Required: your Microsoft Foundry resource endpoint
AZURE_AI_ENDPOINT=https://your-resource.services.ai.azure.com

# Model to use (default: gpt-realtime)
VOICE_LIVE_MODEL=gpt-realtime

# Bring Your Own Model (BYOM): use a custom deployment in your Foundry resource.
# Docs: https://learn.microsoft.com/azure/ai-services/speech-service/how-to-bring-your-own-model
# When ENABLE_BYOM_MODE=true, VOICE_BYOM_MODEL is sent as the `model` query param
# (it must be the deployment NAME from your Foundry portal, not the underlying model id).
ENABLE_BYOM_MODE=false
# Profile: byom-azure-openai-realtime | byom-azure-openai-chat-completion | byom-foundry-anthropic-messages
VOICE_BYOM_MODE=byom-azure-openai-realtime
# Your Foundry deployment name (e.g. "gpt-realtime-1.5" if that's what you named the deployment)
VOICE_BYOM_MODEL=
# Optional: target a deployment in a DIFFERENT Foundry resource. Resource name only, no domain.
# Example: if endpoint is https://my-other-foundry.services.ai.azure.com, set this to "my-other-foundry".
VOICE_BYOM_FOUNDRY_RESOURCE_OVERRIDE=

# Server port (default: 8000)
PORT=8000

# Enable the get_weather function tool (default: false).
# When true, the model can call Open-Meteo (keyless) to answer weather questions,
# including "near me" lookups using the browser's geolocation coordinates.
ENABLE_WEATHER_TOOL=false

# Authentication: uses DefaultAzureCredential (Azure CLI / managed identity).
# Run: az login
# Required roles: Cognitive Services User + Azure AI User
